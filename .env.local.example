# ─── Reown / WalletConnect ────────────────────────────────────────────────────
# Get your project ID at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── RPC ─────────────────────────────────────────────────────────────────────
# Arbitrum Sepolia — used by the frontend and Hardhat deploy scripts.
# Public fallback is fine for dev; use Alchemy/Infura for production.
NEXT_PUBLIC_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ─── Deployment ──────────────────────────────────────────────────────────────
# WARNING: never commit real private keys. Use a dedicated deployer wallet
# funded with Arbitrum Sepolia ETH only.
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key_here

# Arbiscan API key for contract verification.
# Get one at https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# ─── ChainGPT ─────────────────────────────────────────────────────────────────
# Required for /api/analyze-strategy and /api/audit-contract.
# Get yours at https://app.chaingpt.org
# If not set, the app uses a template fallback analysis.
CHAINGPT_API_KEY=your_chaingpt_api_key_here
