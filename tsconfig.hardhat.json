{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-hardhat",
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": [
    "hardhat.config.ts",
    "contracts/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "app",
    "components",
    "hooks",
    "lib",
    ".next"
  ]
}
